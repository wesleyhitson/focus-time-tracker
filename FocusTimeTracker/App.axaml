<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FocusTimeTracker.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI,Segoe UI Emoji,Segoe UI Symbol,Arial" />
        </Style>
    </Application.Styles>
</Application>
