<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FocusTimeTracker.ViewModels"
             xmlns:models="using:FocusTimeTracker.Models"
             xmlns:converters="using:FocusTimeTracker.Converters"
             x:Class="FocusTimeTracker.Views.StatisticsView"
             x:DataType="vm:StatisticsViewModel">

    <UserControl.Resources>
        <converters:SelectedButtonConverter x:Key="EqualityConverter"/>
    </UserControl.Resources>

    <ScrollViewer Margin="20">
        <StackPanel Spacing="20">

            <!-- Header -->
            <TextBlock Text="Your Progress"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,10,0,0"/>

            <!-- Summary Cards -->
            <Grid ColumnDefinitions="*,*"  RowDefinitions="Auto,Auto" >

                <!-- Total Focus Time -->
                <Border Grid.Column="0"
                        Background="#7C3AED"
                        BorderThickness="0"
                        Padding="20"
                        CornerRadius="12">
                    <StackPanel Spacing="5">
                        <TextBlock Text="⏱"
                                   FontSize="32"
                                   FontFamily="Segoe UI Emoji,Segoe UI Symbol"/>
                        <TextBlock Text="{Binding TotalFocusTime}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Total Focus Time"
                                   FontSize="12"
                                   Foreground="#E9D5FF"/>
                    </StackPanel>
                </Border>

                <!-- Total Sessions -->
                <Border Grid.Column="1"
                        Background="#3B82F6"
                        BorderThickness="0"
                        Padding="20"
                        CornerRadius="12">
                    <StackPanel Spacing="5">
                        <TextBlock Text="📊"
                                   FontSize="32"
                                   FontFamily="Segoe UI Emoji,Segoe UI Symbol"/>
                        <TextBlock Text="{Binding TotalSessions}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Total Sessions"
                                   FontSize="12"
                                   Foreground="#DBEAFE"/>
                    </StackPanel>
                </Border>

                <!-- Completed Sessions -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="#10B981"
                        BorderThickness="0"
                        Padding="20"
                        CornerRadius="12">
                    <StackPanel Spacing="5">
                        <TextBlock Text="✅"
                                   FontSize="32"
                                   FontFamily="Segoe UI Emoji,Segoe UI Symbol"/>
                        <TextBlock Text="{Binding CompletedSessions}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Completed"
                                   FontSize="12"
                                   Foreground="#D1FAE5"/>
                    </StackPanel>
                </Border>

                <!-- Completion Rate -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="#F59E0B"
                        BorderThickness="0"
                        Padding="20"
                        CornerRadius="12">
                    <StackPanel Spacing="5">
                        <TextBlock Text="🎯"
                                   FontSize="32"
                                   FontFamily="Segoe UI Emoji,Segoe UI Symbol"/>
                        <TextBlock Text="{Binding CompletionRate}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Success Rate"
                                   FontSize="12"
                                   Foreground="#FEF3C7"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Time Period Selector -->
            <Border Background="#2D2D3A"
                    BorderThickness="0"
                    Padding="15"
                    Margin="0,10,0,0"
                    CornerRadius="12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Show last:"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                    <Button Content="7 days"
                            Background="{Binding SelectedDays, Converter={StaticResource EqualityConverter}, ConverterParameter=7}"
                            Foreground="White"
                            FontSize="12"
                            Padding="15,8"
                            CornerRadius="8"
                            Command="{Binding ChangePeriodCommand}"
                            CommandParameter="7"/>
                    <Button Content="30 days"
                            Background="{Binding SelectedDays, Converter={StaticResource EqualityConverter}, ConverterParameter=30}"
                            Foreground="White"
                            FontSize="12"
                            Padding="15,8"
                            CornerRadius="8"
                            Command="{Binding ChangePeriodCommand}"
                            CommandParameter="30"/>
                    <Button Content="90 days"
                            Background="{Binding SelectedDays, Converter={StaticResource EqualityConverter}, ConverterParameter=90}"
                            Foreground="White"
                            FontSize="12"
                            Padding="15,8"
                            CornerRadius="8"
                            Command="{Binding ChangePeriodCommand}"
                            CommandParameter="90"/>
                </StackPanel>
            </Border>

            <!-- Daily Statistics -->
            <TextBlock Text="Daily Breakdown"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,10,0,0"/>

            <ItemsControl ItemsSource="{Binding DailyStats}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:DailyStatistic">
                        <Border Background="#2D2D3A"
                                BorderThickness="0"
                                Padding="15"
                                Margin="0,0,0,10"
                                CornerRadius="10">

                            <Grid ColumnDefinitions="80,*,Auto" >
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DisplayDate}"
                                           Foreground="#A0A0A0"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>

                                <ProgressBar Grid.Column="1"
                                             Value="{Binding TotalMinutes}"
                                             Minimum="0"
                                             Maximum="480"
                                             Foreground="#7C3AED"
                                             VerticalAlignment="Center"
                                             Height="8"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding DisplayHours}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>

