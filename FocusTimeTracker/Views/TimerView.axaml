<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FocusTimeTracker.ViewModels"
             x:Class="FocusTimeTracker.Views.TimerView"
             x:DataType="vm:TimerViewModel">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Timer Display -->
            <Border Background="#1E1E2E"
                    BorderThickness="0"
                    Width="320"
                    Height="320"
                    CornerRadius="160"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <!-- Time Display -->
                <TextBlock Text="{Binding DisplayTime}"
                           FontSize="56"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

                               <!-- Quick Preset Buttons -->
                               <StackPanel Orientation="Horizontal" 
                                           Spacing="10" 
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding CanModifyDuration}">
                                   <Button Content="5 min"
                                           Command="{Binding SetPresetDurationCommand}"
                                           CommandParameter="5"
                                           Background="#3D3D4D"
                                           Foreground="White"
                                           FontSize="14"
                                           Padding="20,10"
                                           CornerRadius="8"/>
                                   <Button Content="25 min"
                                           Command="{Binding SetPresetDurationCommand}"
                                           CommandParameter="25"
                                           Background="#3D3D4D"
                                           Foreground="White"
                                           FontSize="14"
                                           Padding="20,10"
                                           CornerRadius="8"/>
                                   <Button Content="1 hour"
                                           Command="{Binding SetPresetDurationCommand}"
                                           CommandParameter="60"
                                           Background="#3D3D4D"
                                           Foreground="White"
                                           FontSize="14"
                                           Padding="20,10"
                                           CornerRadius="8"/>
                               </StackPanel>

                               <!-- Duration Controls -->
                               <StackPanel Orientation="Horizontal" 
                                           Spacing="15" 
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding CanModifyDuration}">
                                   <Button Content="-"
                                           Command="{Binding DecreaseDurationCommand}"
                                           Width="50"
                                           Height="50"
                                           FontSize="24"
                                           CornerRadius="25"
                                           Background="#2D2D3A"
                                           HorizontalContentAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Padding="0"/>

                                   <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                       <TextBlock Text="{Binding FocusDuration}"
                                                  FontSize="32"
                                                  FontWeight="Bold"
                                                  Foreground="White"/>
                                       <TextBlock Text=" min"
                                                  FontSize="18"
                                                  Foreground="#A0A0A0"
                                                  Margin="5,0,0,0"/>
                                   </StackPanel>

                                   <Button Content="+"
                                           Command="{Binding IncreaseDurationCommand}"
                                           Width="50"
                                           Height="50"
                                           FontSize="24"
                                           CornerRadius="25"
                                           Background="#2D2D3A"
                                           HorizontalContentAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           Padding="0"/>
                               </StackPanel>

            <!-- Category Entry -->
            <Border Background="#2D2D3A"
                    BorderThickness="0"
                    Padding="15,10"
                    CornerRadius="10"
                    IsVisible="{Binding CanModifyDuration}">

                <TextBox Watermark="What are you focusing on?"
                         Text="{Binding Category}"
                         Foreground="White"
                         Background="Transparent"
                         BorderThickness="0"
                         HorizontalAlignment="Stretch"/>
            </Border>

            <!-- Control Buttons -->
            <Grid ColumnDefinitions="*,*" 
                  Margin="0,10,0,0">
                <Button Grid.Column="0"
                        Content="{Binding StartButtonText}"
                        Command="{Binding StartTimerCommand}"
                        Background="#7C3AED"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold"
                        Height="55"
                        CornerRadius="12"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Stop"
                        Command="{Binding StopTimerCommand}"
                        Background="#EF4444"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold"
                        Height="55"
                        CornerRadius="12"
                        IsEnabled="{Binding IsRunning}"
                        Margin="8,0,0,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
            </Grid>

            <!-- Tips -->
            <Border Background="#2D2D3A"
                    BorderThickness="0"
                    Padding="20"
                    Margin="0,20,0,0"
                    CornerRadius="12"
                    IsVisible="{Binding CanModifyDuration}">

                <StackPanel Spacing="8">
                    <TextBlock Text="💡 Focus Tips"
                               FontSize="16"
                               FontWeight="Bold"
                               FontFamily="Segoe UI Emoji"
                               Foreground="White"/>
                    <TextBlock Text="• Silence notifications on your devices"
                               FontSize="14"
                               Foreground="#A0A0A0"/>
                    <TextBlock Text="• Set a clear goal for this session"
                               FontSize="14"
                               Foreground="#A0A0A0"/>
                    <TextBlock Text="• Take breaks between sessions"
                               FontSize="14"
                               Foreground="#A0A0A0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
