<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:FocusTimeTracker.Views"
        x:Class="FocusTimeTracker.Views.MainWindow"
        Title="Focus Time Tracker"
        Width="800"
        Height="600"
        MinWidth="600"
        MinHeight="400">
    <TabControl>
        <TabItem Header="Timer">
            <views:TimerView />
        </TabItem>
        <TabItem Header="History">
            <views:HistoryView />
        </TabItem>
        <TabItem Header="Statistics">
            <views:StatisticsView />
        </TabItem>
        <TabItem Header="Settings">
            <views:SettingsView />
        </TabItem>
    </TabControl>
</Window>
