<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FocusTimeTracker.ViewModels"
             x:Class="FocusTimeTracker.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer Margin="20">
        <StackPanel Spacing="25" MaxWidth="600">

            <!-- Header -->
            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,10,0,0"/>

            <!-- Data Export Section -->
            <Border Background="#2D2D3A"
                    BorderThickness="0"
                    Padding="20"
                    CornerRadius="12">
                <StackPanel Spacing="15">
                    <TextBlock Text="⬇️ Export Data"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Segoe UI Emoji,Segoe UI Symbol"/>

                    <TextBlock Text="Export all your focus sessions to a CSV file. The file will be saved to your Documents folder."
                               FontSize="13"
                               Foreground="#A0A0A0"
                               TextWrapping="Wrap"/>

                    <Button Content="Export to CSV"
                            Command="{Binding ExportDataCommand}"
                            Background="#7C3AED"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20,12"
                            CornerRadius="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>

                    <TextBlock Text="{Binding ExportMessage}"
                               FontSize="12"
                               Foreground="#A0A0A0"
                               TextWrapping="Wrap"
                               IsVisible="{Binding ExportMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </Border>

            <!-- Data Import Section -->
            <Border Background="#2D2D3A"
                    BorderThickness="0"
                    Padding="20"
                    CornerRadius="12">
                <StackPanel Spacing="15">
                    <TextBlock Text="⬆️ Import Data"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Segoe UI Emoji,Segoe UI Symbol"/>

                    <TextBlock Text="Import focus sessions from a CSV file. This will look for exported files in your Documents folder and import the most recent one."
                               FontSize="13"
                               Foreground="#A0A0A0"
                               TextWrapping="Wrap"/>

                    <Button Content="Import from CSV"
                            Command="{Binding ImportDataCommand}"
                            Background="#3B82F6"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20,12"
                            CornerRadius="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>

                    <TextBlock Text="{Binding ImportMessage}"
                               FontSize="12"
                               Foreground="#A0A0A0"
                               TextWrapping="Wrap"
                               IsVisible="{Binding ImportMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </Border>

            <!-- Info Section -->
            <Border Background="#2D2D3A"
                    BorderThickness="0"
                    Padding="20"
                    CornerRadius="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="ℹ️ About"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Segoe UI Emoji,Segoe UI Symbol"/>

                    <TextBlock Text="Focus Time Tracker"
                               FontSize="14"
                               Foreground="#A0A0A0"/>
                    <TextBlock Text="Version 1.0.0"
                               FontSize="13"
                               Foreground="#6B6B7B"/>
                    <TextBlock Text="A Pomodoro-style focus timer to help you stay productive."
                               FontSize="13"
                               Foreground="#6B6B7B"
                               TextWrapping="Wrap"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
